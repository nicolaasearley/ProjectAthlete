# Fitness Earley v2 - Environment Variables
# Copy this file to .env and fill in the values

# ============================================
# DATABASE CONFIGURATION
# ============================================
# For Docker: Use service names (postgres, redis)
# For PM2/Non-Docker: Use localhost or actual IPs

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fitness_earley
POSTGRES_PORT=5432
# For Docker: postgresql://postgres:postgres@postgres:5432/fitness_earley?schema=public
# For PM2: postgresql://postgres:postgres@localhost:5432/fitness_earley?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fitness_earley?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# For Docker: redis://redis:6379
# For PM2: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# JWT Secrets (Generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET=your-jwt-access-secret-change-in-production
JWT_REFRESH_SECRET=your-jwt-refresh-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# APPLICATION CONFIGURATION
# ============================================
NODE_ENV=development
API_PORT=3000
API_HOST=0.0.0.0
FRONTEND_PORT=5173
FRONTEND_URL=http://localhost:5173

# API URL for frontend (Docker: http://backend:3000, PM2: http://localhost:3000)
API_URL=http://localhost:3000

# ============================================
# STORAGE CONFIGURATION
# ============================================
STORAGE_PROVIDER=local
UPLOADS_DIR=/data/uploads
MEDIA_PUBLIC_URL=/media

# OAuth (Optional - for future implementation)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# SMTP (Optional - for email verification)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@fitnessearley.com

# Monitoring
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-production

# Backup
BACKUP_RETENTION_DAYS_LOCAL=7
BACKUP_RETENTION_DAYS_EXTERNAL=30

# Domain (for Traefik and Let's Encrypt)
DOMAIN=localhost
LETSENCRYPT_EMAIL=

